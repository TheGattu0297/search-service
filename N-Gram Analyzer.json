          "raw": {
            "type": "keyword"
          }
        }
      },
      "reg": {
        "type": "text",
        "analyzer": "autocomplete",
        "search_analyzer": "standard",
        "fields": {
          "raw": {
            "type": "keyword"
          }
        }
      },
      "sub": {
        "type": "text",
        "analyzer": "autocomplete",
        "search_analyzer": "standard",
        "fields": {
          "raw": {
            "type": "keyword"
          }
        }
      },
      "deno": {
        "type": "text",
        "analyzer": "autocomplete",
        "search_analyzer": "standard",
        "fields": {
          "raw": {
            "type": "keyword"
          }
        }
      },
      "prod": {
        "type": "text",
        "analyzer": "autocomplete",
        "search_analyzer": "standard",
        "fields": {
          "raw": {
            "type": "keyword"
          }

//PUT /products
{
  "settings": {
    "analysis": {
      "tokenizer": {
        "edge_ngram_tokenizer": {
          "type": "edge_ngram",
          "min_gram": 1,
          "max_gram": 20,
          "token_chars": [
            "letter",
            "digit",
            "punctuation",
            "symbol"
          ]
        }
      },
      "analyzer": {
        "autocomplete": {
          "type": "custom",
          "tokenizer": "edge_ngram_tokenizer",
          "filter": ["lowercase"]
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "productID": {
        "type": "keyword"
      },
      "master": {
        "type": "text",
        "index": true
      },
      "country": {
        "type": "text",
        "analyzer": "autocomplete",
        "search_analyzer": "standard",
        "fields": {
          "raw": {
            "type": "keyword"
          }
        }
      },
      "countryFlag": {
        "type": "text",
        "index": false
      },
      "type": {
        "type": "text",
        "analyzer": "autocomplete",
        "search_analyzer": "standard",
        "fields": {
          "raw": {
            "type": "keyword"
          }
        }
      },
      "subType": {
        "type": "text",
        "analyzer": "autocomplete",
        "search_analyzer": "standard",
